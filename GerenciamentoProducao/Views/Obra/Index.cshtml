@model IEnumerable<GerenciamentoProducao.Models.Obra>

@{
    ViewData["Title"] = "Obras";
    var filtro = ViewBag.Filtro as string ?? "andamento";
}

<div class="container-fluid">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <div>
                <h1 class="h3 mb-0">Obras</h1>
                <p class="mb-0">Gerenciamento de obras e projetos</p>
            </div>
            @if (User.IsInRole("Administrador") || User.IsInRole("Gerente"))
            {
                <a asp-action="Create" class="btn btn-primary btn-sm">
                    <i class="fas fa-plus"></i> Nova Obra
                </a>
            }
        </div>
    </div>

    @* Filtros em abas *@
    <ul class="nav nav-tabs mb-4" role="tablist">
        <li class="nav-item">
            <a class="nav-link @(filtro == "todas" ? "active" : "")" asp-action="Index" asp-route-filtro="todas">
                <i class="fas fa-list me-1"></i> Todas
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(filtro == "andamento" ? "active" : "")" asp-action="Index" asp-route-filtro="andamento">
                <i class="fas fa-hammer me-1"></i> Em Andamento
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(filtro == "concluidas" ? "active" : "")" asp-action="Index" asp-route-filtro="concluidas">
                <i class="fas fa-check-circle me-1"></i> Concluidas
            </a>
        </li>
    </ul>

    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">
                        @(filtro == "concluidas" ? "Obras Concluidas" : filtro == "todas" ? "Todas as Obras" : "Obras em Andamento")
                    </h6>
                </div>
                <div class="card-body">
                    @if (!Model.Any())
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-hard-hat fa-3x mb-3" style="color:var(--gp-muted-color);opacity:.4;"></i>
                            <p style="color:var(--gp-muted-color);">Nenhuma obra encontrada.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover" width="100%" cellspacing="0">
                                <thead>
                                    <tr>
                                        <th class="text-center">Imagem</th>
                                        <th>Nome</th>
                                        <th>Construtora</th>
                                        <th>Periodo</th>
                                        <th>Peso</th>
                                        <th>Medicao</th>
                                        <th>Producao</th>
                                        <th>Status</th>
                                        <th>Acoes</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="text-center align-middle">
                                                @if (!string.IsNullOrEmpty(item.ImagemObraPath))
                                                {
                                                    <img src="@Url.Content("~/" + item.ImagemObraPath)" alt="Imagem de @item.Nome" class="img-thumbnail" style="width: 80px; height: 80px; object-fit: cover;" />
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">Sem imagem</span>
                                                }
                                            </td>
                                            <td>
                                                <strong>@item.Nome</strong>
                                                @if (!string.IsNullOrEmpty(item.Observacoes))
                                                {
                                                    <br><small class="text-muted">@item.Observacoes</small>
                                                }
                                            </td>
                                            <td>@item.Construtora</td>
                                            <td>
                                                <small>
                                                    <strong>Inicio:</strong> @item.DataInicio.ToString("dd/MM/yyyy")<br>
                                                    <strong>Termino:</strong> @item.DataTermino.ToString("dd/MM/yyyy")
                                                </small>
                                            </td>
                                            <td>
                                                <small>
                                                    <strong>Final:</strong> @item.PesoFinal.ToString("F0") kg
                                                </small>
                                            </td>
                                            <td style="min-width:120px;">
                                                <div class="progress mb-1" style="height: 18px;">
                                                    <div class="progress-bar @(item.PercentualMedicao >= 100 ? "bg-success" : item.PercentualMedicao >= 50 ? "bg-info" : "bg-warning")"
                                                         role="progressbar"
                                                         style="width: @item.PercentualMedicao%"
                                                         aria-valuenow="@item.PercentualMedicao"
                                                         aria-valuemin="0"
                                                         aria-valuemax="100">
                                                        @item.PercentualMedicao.ToString("F0")%
                                                    </div>
                                                </div>
                                                <small class="text-muted">Medicao</small>
                                            </td>
                                            <td style="min-width:120px;">
                                                <div class="progress mb-1" style="height: 18px;">
                                                    <div class="progress-bar @(item.PercentualProducao >= 100 ? "bg-success" : item.PercentualProducao >= 50 ? "bg-primary" : "bg-secondary")"
                                                         role="progressbar"
                                                         style="width: @item.PercentualProducao%"
                                                         aria-valuenow="@item.PercentualProducao"
                                                         aria-valuemin="0"
                                                         aria-valuemax="100">
                                                        @item.PercentualProducao.ToString("F0")%
                                                    </div>
                                                </div>
                                                <small class="text-muted">Producao</small>
                                            </td>
                                            <td>
                                                <span class="badge text-bg-@(item.StatusObra == "Concluida" ? "success" : item.StatusObra == "EmProducao" ? "primary" : item.StatusObra == "EmMedicao" ? "info" : "secondary")">
                                                    @item.StatusObra
                                                </span>
                                            </td>
                                            <td>
                                                @{
                                                    var isGestorObra = User.IsInRole("Administrador") || User.IsInRole("Gerente");
                                                    var obraPodeFinalizar = item.StatusObra != "Concluida"
                                                        && item.PercentualMedicao >= 99.99f
                                                        && item.PercentualProducao >= 99.99f;
                                                }
                                                <div class="d-flex flex-wrap gap-1 align-items-center">
                                                    <div class="btn-group" role="group">
                                                        <a asp-action="Details" asp-route-id="@item.IdObra" class="btn btn-sm btn-info" title="Ver detalhes">
                                                            <i class="fas fa-eye"></i>
                                                        </a>
                                                        @if (isGestorObra)
                                                        {
                                                            <a asp-action="Edit" asp-route-id="@item.IdObra" class="btn btn-sm btn-warning" title="Editar">
                                                                <i class="fas fa-edit"></i>
                                                            </a>
                                                            <a asp-action="Delete" asp-route-id="@item.IdObra" class="btn btn-sm btn-danger" title="Eliminar">
                                                                <i class="fas fa-trash"></i>
                                                            </a>
                                                        }
                                                    </div>
                                                    @if (isGestorObra && obraPodeFinalizar)
                                                    {
                                                        <form asp-action="ConcluirObra" asp-controller="Obra" method="post" class="d-inline m-0">
                                                            <input type="hidden" name="id" value="@item.IdObra" />
                                                            <button type="submit" class="btn btn-sm btn-success" title="Medição e produção em 100%"
                                                                    onclick="return confirm('Finalizar a obra &quot;@item.Nome&quot;?');">
                                                                <i class="fas fa-flag-checkered me-1"></i>Finalizar
                                                            </button>
                                                        </form>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
