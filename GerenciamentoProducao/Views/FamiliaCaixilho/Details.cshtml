@model GerenciamentoProducao.Models.FamiliaCaixilho

@{
    ViewData["Title"] = "Família - " + Model.DescricaoFamilia;
    var caixilhos = ViewBag.Caixilhos as List<GerenciamentoProducao.Models.Caixilho> ?? new List<GerenciamentoProducao.Models.Caixilho>();
    var obraNome = ViewBag.ObraNome as string;
    var temCaixilhos = caixilhos.Any();
    var todosMedidos = temCaixilhos && caixilhos.All(c => c.StatusProducao == "Medido");
    var pendentes = caixilhos.Count(c => c.StatusProducao != "Medido");
    var medidos = caixilhos.Count(c => c.StatusProducao == "Medido");
    var jaLiberada = Model.StatusFamilia == "EmProducao" || Model.StatusFamilia == "Produzida";
    var emProducao = Model.StatusFamilia == "EmProducao";
    var producaoConcluida = Model.StatusFamilia == "Produzida";
    var medicaoPendente = ViewBag.MedicaoFotoPendente as FamiliaMedicaoFotoState;
    var aguardandoAprovacaoFoto = medicaoPendente != null && !medicaoPendente.Aprovada;
    var producao = ViewBag.ProducaoFamilia as GerenciamentoProducao.Models.ProducaoFamiliaResponseDto;
    var medicaoApi = ViewBag.MedicaoFamilia as GerenciamentoProducao.Models.MedicaoResponseDto;
    var statusExibicao = aguardandoAprovacaoFoto ? "PendenteAprovacaoMedicao" : Model.StatusFamilia;
    var isAdmin = User.IsInRole("Administrador");
    var isAdminOuGerente = User.IsInRole("Administrador") || User.IsInRole("Gerente");
    var solicitacoes = ViewBag.SolicitacoesCliente as List<GerenciamentoProducao.Models.SolicitacaoClienteResponseDto> ?? new List<GerenciamentoProducao.Models.SolicitacaoClienteResponseDto>();
    var temSolicitacoes = solicitacoes.Any();
}

<div class="container-fluid">

    @* Breadcrumb / Cabeçalho *@
    <div class="row mb-3">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-1">
                        <li class="breadcrumb-item">
                            <a asp-controller="Obra" asp-action="Index" style="color:var(--gp-muted-color);">Obras</a>
                        </li>
                        @if (!string.IsNullOrEmpty(obraNome))
                        {
                            <li class="breadcrumb-item">
                                <a asp-controller="Obra" asp-action="Details" asp-route-id="@Model.IdObra" style="color:var(--gp-muted-color);">@obraNome</a>
                            </li>
                        }
                        <li class="breadcrumb-item active" aria-current="page" style="color:var(--gp-body-color);">@Model.DescricaoFamilia</li>
                    </ol>
                </nav>
                <h1 class="h3 mb-0" style="color:var(--gp-heading-color);">
                    <i class="fas fa-layer-group me-2"></i>@Model.DescricaoFamilia
                </h1>
            </div>
            <div class="d-flex gap-2">
                @if (User.IsInRole("Administrador") || User.IsInRole("Gerente"))
                {
                    <a asp-action="Create" asp-controller="Caixilho" asp-route-familiaId="@Model.IdFamiliaCaixilho" class="btn btn-primary btn-sm">
                        <i class="fas fa-plus"></i> Novo Caixilho
                    </a>
                    <a asp-action="Edit" asp-route-id="@Model.IdFamiliaCaixilho" class="btn btn-warning btn-sm">
                        <i class="fas fa-edit"></i> Editar Família
                    </a>
                }
                <a asp-controller="Obra" asp-action="Details" asp-route-id="@Model.IdObra" class="btn btn-secondary btn-sm">
                    <i class="fas fa-arrow-left"></i> Voltar para Obra
                </a>
            </div>
        </div>
    </div>

    @* Cards de resumo da família *@
    <div class="row mb-4 g-3">
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-info d-flex align-items-center justify-content-center flex-shrink-0" style="width:44px;height:44px;">
                        <i class="fas fa-window-restore text-white"></i>
                    </div>
                    <div>
                        <div class="small" style="color:var(--gp-muted-color);">Caixilhos</div>
                        <div class="fw-bold fs-5" style="color:var(--gp-body-color);">@caixilhos.Count</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-success d-flex align-items-center justify-content-center flex-shrink-0" style="width:44px;height:44px;">
                        <i class="fas fa-weight text-white"></i>
                    </div>
                    <div>
                        <div class="small" style="color:var(--gp-muted-color);">Peso Total</div>
                        <div class="fw-bold fs-5" style="color:var(--gp-body-color);">@Model.PesoTotal kg</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle @(todosMedidos ? "bg-success" : "bg-warning") d-flex align-items-center justify-content-center flex-shrink-0" style="width:44px;height:44px;">
                        <i class="fas fa-ruler text-white"></i>
                    </div>
                    <div>
                        <div class="small" style="color:var(--gp-muted-color);">Medição</div>
                        <div class="fw-bold fs-5" style="color:var(--gp-body-color);">@medidos / @caixilhos.Count</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle text-bg-@(aguardandoAprovacaoFoto ? "warning" : Model.StatusFamilia == "Produzida" ? "success" : Model.StatusFamilia == "EmProducao" ? "primary" : Model.StatusFamilia == "Medida" ? "info" : "secondary") d-flex align-items-center justify-content-center flex-shrink-0" style="width:44px;height:44px;">
                        <i class="fas fa-flag text-white"></i>
                    </div>
                    <div>
                        <div class="small" style="color:var(--gp-muted-color);">Status</div>
                        <div class="fw-bold" style="color:var(--gp-body-color);">@statusExibicao</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* Fluxo: enviar foto → aprovar na web = Medido | rejeitar = enviar foto de novo. Produção = passo seguinte (liberar). *@
    @if (producaoConcluida)
    {
        <div class="alert alert-success d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4" role="alert">
            <div class="d-flex align-items-center gap-3">
                <i class="fas fa-flag-checkered fa-2x"></i>
                <div>
                    <strong>Produção desta família concluída</strong>
                    <div class="small">Esta família entra no percentual de produção da obra como finalizada. Quando todas as famílias estiverem assim e a medição em 100%, pode concluir a obra.</div>
                </div>
            </div>
        </div>
    }
    else if (emProducao)
    {
        <div class="alert alert-primary d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4" role="alert">
            <div class="d-flex align-items-center gap-3">
                <i class="fas fa-industry fa-2x"></i>
                <div>
                    <strong>Família liberada — em produção</strong>
                    <div class="small">Quando a produção desta família terminar no chão de fábrica, marque como concluída para atualizar o progresso da obra.</div>
                </div>
            </div>
            @if (isAdminOuGerente)
            {
                <form asp-action="FinalizarProducaoFamilia" asp-controller="FamiliaCaixilho" method="post" class="d-inline m-0">
                    <input type="hidden" name="id" value="@Model.IdFamiliaCaixilho" />
                    <button type="submit" class="btn btn-success" onclick="return confirm('Marcar a produção desta família como concluída? Isto atualiza o percentual da obra.')">
                        <i class="fas fa-flag-checkered me-1"></i> Finalizar produção da família
                    </button>
                </form>
            }
        </div>
    }
    else if (aguardandoAprovacaoFoto)
    {
        <div class="card border-warning shadow-sm mb-4">
            <div class="card-header bg-warning bg-opacity-25 d-flex align-items-center gap-2">
                <i class="fas fa-hourglass-half text-warning"></i>
                <strong>Foto da medição aguardando aprovação (só na web)</strong>
            </div>
            <div class="card-body">
                <p class="small text-muted mb-2">
                    Enviada em @medicaoPendente!.EnviadoEm.ToLocalTime().ToString("g")
                    @if (!string.IsNullOrEmpty(medicaoPendente.EnviadoPor))
                    { <text>por <strong>@medicaoPendente.EnviadoPor</strong></text> }
                </p>
                <p class="small mb-3">Se <strong>aprovar</strong>, todos os caixilhos passam a <strong>Medido</strong>. Se <strong>rejeitar</strong>, a foto é apagada e pode enviar outra (telemóvel ou web).</p>
                <div class="mb-3 text-center">
                    <img src="@medicaoPendente.FotoBase64" alt="Foto da medição" class="img-fluid rounded border" style="max-height: 420px;" />
                </div>
                @if (isAdminOuGerente)
                {
                    <div class="d-flex flex-wrap gap-2 align-items-center">
                        <form asp-action="AprovarMedicaoFoto" asp-controller="FamiliaCaixilho" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@Model.IdFamiliaCaixilho" />
                            <button type="submit" class="btn btn-success" onclick="return confirm('Aprovar e marcar todos os caixilhos como Medido?')">
                                <i class="fas fa-check me-1"></i> Aprovar e marcar como Medido
                            </button>
                        </form>
                        <form asp-action="RejeitarMedicaoFoto" asp-controller="FamiliaCaixilho" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@Model.IdFamiliaCaixilho" />
                            <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Rejeitar esta foto? Ela será eliminada e poderão enviar outra.')">
                                <i class="fas fa-times me-1"></i> Rejeitar foto
                            </button>
                        </form>
                        @if (isAdmin && todosMedidos)
                        {
                            <form asp-action="LiberarProducao" asp-controller="FamiliaCaixilho" method="post" class="d-inline ms-md-2">
                                <input type="hidden" name="id" value="@Model.IdFamiliaCaixilho" />
                                <button type="submit" class="btn btn-outline-secondary" onclick="return confirm('Liberar para produção? A foto pendente será removida.')">
                                    <i class="fas fa-forward me-1"></i> Ir para produção (admin, remove foto pendente)
                                </button>
                            </form>
                        }
                    </div>
                }
                else
                {
                    <p class="mb-0 text-muted small"><i class="fas fa-info-circle me-1"></i>A aprovação ou rejeição é feita na web por administrador ou gerente. No telemóvel só é possível enviar a foto.</p>
                }
            </div>
        </div>
    }
    else if (todosMedidos)
    {
        <div class="alert alert-info mb-4" role="alert">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3">
                <div class="d-flex align-items-center gap-3">
                    <i class="fas fa-clipboard-check fa-2x"></i>
                    <div>
                        <strong>Todos os caixilhos estão medidos</strong>
                        <div class="small">A medição foi confirmada (foto aprovada ou ajuste manual). <strong>Administrador</strong> pode liberar a família para produção.</div>
                    </div>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    @if (isAdmin)
                    {
                        <form asp-action="LiberarProducao" asp-controller="FamiliaCaixilho" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@Model.IdFamiliaCaixilho" />
                            <button type="submit" class="btn btn-success" onclick="return confirm('Liberar esta família para produção?')">
                                <i class="fas fa-industry me-1"></i> Liberar para produção
                            </button>
                        </form>
                    }
                </div>
            </div>
            @if (User.IsInRole("Gerente") && !isAdmin)
            {
                <hr class="my-2" />
                <p class="small mb-0"><i class="fas fa-user-shield me-1"></i>Só um administrador pode liberar para produção. Se faltar foto aprovada, envie-a no telemóvel e aprove na web.</p>
            }
        </div>
    }
    else if (temCaixilhos)
    {
        <div class="alert alert-warning mb-4" role="alert">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3">
                <div class="d-flex align-items-center gap-3">
                    <i class="fas fa-exclamation-triangle fa-2x"></i>
                    <div>
                        <strong>Medição em andamento</strong>
                        <div class="small">@pendentes caixilho(s) ainda não medido(s). Envie a <strong>foto da medição</strong>; após aprovação na web, todos passam a Medido. Se a foto for rejeitada, envie outra.</div>
                    </div>
                </div>
                <div>
                    <a asp-action="EnviarFotoMedicao" asp-controller="FamiliaCaixilho" asp-route-id="@Model.IdFamiliaCaixilho" class="btn btn-primary">
                        <i class="fas fa-camera me-1"></i> Enviar foto da medição
                    </a>
                </div>
            </div>
        </div>
    }

    @* Cards de atividade: medição e produção *@
    <div class="row mb-4 g-3">
        @if (medicaoApi != null)
        {
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-header py-2">
                        <i class="fas fa-ruler-combined me-2 text-info"></i><strong>Atividade de Medição</strong>
                    </div>
                    <div class="card-body">
                        <div class="row g-2 small">
                            <div class="col-6">
                                <span style="color:var(--gp-muted-color);">Status:</span><br>
                                <span class="badge text-bg-info">@medicaoApi.StatusTexto</span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(medicaoApi.NomeResponsavel))
                            {
                                <div class="col-6">
                                    <span style="color:var(--gp-muted-color);">Responsável:</span><br>
                                    <strong>@medicaoApi.NomeResponsavel</strong>
                                </div>
                            }
                            @if (medicaoApi.DataInicio.HasValue)
                            {
                                <div class="col-6">
                                    <span style="color:var(--gp-muted-color);">Início:</span><br>
                                    <strong>@medicaoApi.DataInicio.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</strong>
                                </div>
                            }
                            @if (medicaoApi.DataConclusao.HasValue)
                            {
                                <div class="col-6">
                                    <span style="color:var(--gp-muted-color);">Conclusão:</span><br>
                                    <strong>@medicaoApi.DataConclusao.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</strong>
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(medicaoApi.Descricao))
                            {
                                <div class="col-12">
                                    <span style="color:var(--gp-muted-color);">Descrição:</span><br>
                                    @medicaoApi.Descricao
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(medicaoApi.Observacoes))
                            {
                                <div class="col-12 mt-1">
                                    <div class="p-2 rounded" style="background:rgba(25,135,84,.1);border-left:3px solid #198754;">
                                        <strong style="color:#198754;"><i class="fas fa-comment-alt me-1"></i>Observações:</strong><br>
                                        @medicaoApi.Observacoes
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
        @if (producao != null)
        {
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-header py-2">
                        <i class="fas fa-industry me-2 text-primary"></i><strong>Atividade de Produção</strong>
                    </div>
                    <div class="card-body">
                        <div class="row g-2 small">
                            <div class="col-6">
                                <span style="color:var(--gp-muted-color);">Status:</span><br>
                                <span class="badge text-bg-@(producao.Status == 4 ? "success" : producao.Status == 2 ? "primary" : producao.Status == 3 ? "warning" : "secondary")">
                                    @producao.StatusTexto
                                </span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(producao.NomeResponsavel))
                            {
                                <div class="col-6">
                                    <span style="color:var(--gp-muted-color);">Responsável:</span><br>
                                    <strong>@producao.NomeResponsavel</strong>
                                </div>
                            }
                            @if (producao.DataInicio.HasValue)
                            {
                                <div class="col-6">
                                    <span style="color:var(--gp-muted-color);">Início:</span><br>
                                    <strong>@producao.DataInicio.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</strong>
                                </div>
                            }
                            @if (producao.DataConclusao.HasValue)
                            {
                                <div class="col-6">
                                    <span style="color:var(--gp-muted-color);">Conclusão:</span><br>
                                    <strong>@producao.DataConclusao.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</strong>
                                </div>
                            }
                            @if (producao.DataEstimadaConclusao.HasValue)
                            {
                                <div class="col-6">
                                    <span style="color:var(--gp-muted-color);">Previsão:</span><br>
                                    <strong>@producao.DataEstimadaConclusao.Value.ToString("dd/MM/yyyy")</strong>
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(producao.Descricao))
                            {
                                <div class="col-12">
                                    <span style="color:var(--gp-muted-color);">Descrição:</span><br>
                                    @producao.Descricao
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(producao.Observacoes))
                            {
                                <div class="col-12 mt-1">
                                    <div class="p-2 rounded" style="background:rgba(25,135,84,.1);border-left:3px solid #198754;">
                                        <strong style="color:#198754;"><i class="fas fa-comment-alt me-1"></i>Observações:</strong><br>
                                        @producao.Observacoes
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @* Solicitações do cliente *@
    @if (temSolicitacoes)
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header py-2 d-flex justify-content-between align-items-center">
                <div>
                    <i class="fas fa-bell me-2 text-warning"></i>
                    <strong>Solicitações do Cliente</strong>
                    <span class="badge bg-warning text-dark ms-2">@solicitacoes.Count</span>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Caixilho</th>
                                <th>Cliente</th>
                                <th class="text-center">Prioridade</th>
                                <th class="text-center">Necessário em</th>
                                <th>Observação</th>
                                <th class="text-center">Solicitado em</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sol in solicitacoes.OrderByDescending(s => s.Prioridade))
                            {
                                var prioridadeClass = sol.Prioridade switch
                                {
                                    2 => "bg-danger",
                                    1 => "bg-warning text-dark",
                                    _ => "bg-secondary"
                                };
                                var prioridadeLabel = sol.Prioridade switch
                                {
                                    2 => "Urgente",
                                    1 => "Importante",
                                    _ => "Normal"
                                };
                                var atrasado = sol.DataNecessidadeEmObra.ToLocalTime().Date < DateTime.Today;
                                <tr class="@(atrasado ? "table-danger" : "")">
                                    <td><strong>@sol.NomeCaixilho</strong></td>
                                    <td>@sol.NomeCliente</td>
                                    <td class="text-center">
                                        <span class="badge @prioridadeClass">@prioridadeLabel</span>
                                    </td>
                                    <td class="text-center @(atrasado ? "text-danger fw-bold" : "")">
                                        @sol.DataNecessidadeEmObra.ToLocalTime().ToString("dd/MM/yyyy")
                                        @if (atrasado)
                                        {
                                            <br><small>ATRASADO</small>
                                        }
                                    </td>
                                    <td><small style="color:var(--gp-muted-color);">@(sol.ObservacaoCliente ?? "—")</small></td>
                                    <td class="text-center"><small>@sol.DataSolicitacao.ToLocalTime().ToString("dd/MM/yyyy")</small></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @* Tabela de caixilhos *@
    <div class="card border-0 shadow">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
            <h6 class="m-0 fw-bold" style="color:var(--gp-heading-color);">
                <i class="fas fa-window-restore me-2"></i>Caixilhos desta Família
            </h6>
            @if (User.IsInRole("Administrador") || User.IsInRole("Gerente"))
            {
                <a asp-action="Create" asp-controller="Caixilho" asp-route-familiaId="@Model.IdFamiliaCaixilho" class="btn btn-primary btn-sm">
                    <i class="fas fa-plus"></i> Novo Caixilho
                </a>
            }
        </div>
        <div class="card-body p-0">
            @if (!caixilhos.Any())
            {
                <div class="text-center py-5">
                    <i class="fas fa-window-restore fa-3x mb-3" style="color:var(--gp-muted-color);opacity:.4;"></i>
                    <p style="color:var(--gp-muted-color);">Nenhum caixilho cadastrado nesta família.</p>
                    @if (User.IsInRole("Administrador") || User.IsInRole("Gerente"))
                    {
                        <a asp-action="Create" asp-controller="Caixilho" asp-route-familiaId="@Model.IdFamiliaCaixilho" class="btn btn-primary">
                            <i class="fas fa-plus"></i> Criar primeiro caixilho
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-bordered table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Nome</th>
                                <th>Tipo</th>
                                <th class="text-center">Larg. × Alt. (cm)</th>
                                <th class="text-center">Qtd.</th>
                                <th class="text-center">Peso Unit. (kg)</th>
                                <th class="text-center">Peso Total (kg)</th>
                                <th class="text-center">Medição</th>
                                <th class="text-center">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in caixilhos)
                            {
                                <tr>
                                    <td><strong>@c.NomeCaixilho</strong></td>
                                    <td><small style="color:var(--gp-muted-color);">@c.DescricaoCaixilho</small></td>
                                    <td class="text-center">@c.Largura × @c.Altura</td>
                                    <td class="text-center">@c.Quantidade</td>
                                    <td class="text-center">@c.PesoUnitario.ToString("F1")</td>
                                    <td class="text-center">@((c.PesoUnitario * c.Quantidade).ToString("F1"))</td>
                                    <td class="text-center">
                                        @{
                                            var isMedido = c.StatusProducao == "Medido";
                                            var canToggle = !jaLiberada && !aguardandoAprovacaoFoto && (User.IsInRole("Administrador") || User.IsInRole("Gerente"));
                                        }
                                        @if (canToggle)
                                        {
                                            <form asp-controller="Caixilho"
                                                  asp-action="@(isMedido ? "DesmarcarMedido" : "MarcarMedido")"
                                                  method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@c.IdCaixilho" />
                                                <input type="hidden" name="familiaId" value="@Model.IdFamiliaCaixilho" />
                                                <label class="medicao-toggle" title="@(isMedido ? "Clique para voltar a Pendente" : "Clique para marcar como Medido")">
                                                    <input type="checkbox" onchange="this.form.submit()"
                                                           @(isMedido ? "checked" : "") />
                                                    <span class="medicao-slider">
                                                        <span class="medicao-label-off">Pendente</span>
                                                        <span class="medicao-label-on">Medido</span>
                                                    </span>
                                                </label>
                                            </form>
                                        }
                                        else
                                        {
                                            @if (isMedido)
                                            {
                                                <span class="badge text-bg-success"><i class="fas fa-check me-1"></i>Medido</span>
                                            }
                                            else
                                            {
                                                <span class="badge text-bg-warning"><i class="fas fa-clock me-1"></i>Pendente</span>
                                            }
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-controller="Caixilho" asp-action="Details" asp-route-id="@c.IdCaixilho" class="btn btn-info">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            @if (User.IsInRole("Administrador") || User.IsInRole("Gerente"))
                                            {
                                                <a asp-controller="Caixilho" asp-action="Edit" asp-route-id="@c.IdCaixilho" class="btn btn-warning">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <a asp-controller="Caixilho" asp-action="Delete" asp-route-id="@c.IdCaixilho" class="btn btn-danger">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-light fw-bold">
                                <td colspan="3">Total</td>
                                <td class="text-center">@caixilhos.Sum(c => c.Quantidade)</td>
                                <td></td>
                                <td class="text-center">@caixilhos.Sum(c => c.PesoUnitario * c.Quantidade).ToString("F1")</td>
                                <td colspan="3"></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
        </div>
    </div>

</div>

<style>
    .medicao-toggle {
        position: relative;
        display: inline-block;
        width: 120px;
        height: 34px;
        cursor: pointer;
        margin: 0;
    }
    .medicao-toggle input {
        opacity: 0;
        width: 0;
        height: 0;
        position: absolute;
    }
    .medicao-slider {
        position: absolute;
        inset: 0;
        background: #e0a800;
        border-radius: 34px;
        transition: background .3s;
        overflow: hidden;
    }
    .medicao-slider::before {
        content: "";
        position: absolute;
        height: 26px;
        width: 26px;
        left: 4px;
        bottom: 4px;
        background: white;
        border-radius: 50%;
        transition: transform .3s;
        z-index: 2;
        box-shadow: 0 1px 3px rgba(0,0,0,.3);
    }
    .medicao-toggle input:checked + .medicao-slider {
        background: #198754;
    }
    .medicao-toggle input:checked + .medicao-slider::before {
        transform: translateX(86px);
    }
    .medicao-label-off,
    .medicao-label-on {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        font-size: 11px;
        font-weight: 700;
        color: white;
        pointer-events: none;
        transition: opacity .3s;
        white-space: nowrap;
    }
    .medicao-label-off {
        right: 12px;
        opacity: 1;
    }
    .medicao-label-on {
        left: 12px;
        opacity: 0;
    }
    .medicao-toggle input:checked + .medicao-slider .medicao-label-off {
        opacity: 0;
    }
    .medicao-toggle input:checked + .medicao-slider .medicao-label-on {
        opacity: 1;
    }
    .medicao-toggle:hover .medicao-slider {
        filter: brightness(1.1);
    }
</style>
