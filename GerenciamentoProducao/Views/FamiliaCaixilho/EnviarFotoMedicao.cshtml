@{
    ViewData["Title"] = "Foto da medição";
    var idFamilia = (int)(ViewBag.IdFamilia ?? 0);
    var nome = ViewBag.FamiliaNome as string ?? "Família";
}

<div class="container-fluid" style="max-width: 720px;">
    <div class="mb-3">
        <a asp-action="Details" asp-route-id="@idFamilia" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-arrow-left me-1"></i> Voltar
        </a>
    </div>
    <h1 class="h4 mb-3" style="color:var(--gp-heading-color);">
        <i class="fas fa-camera me-2"></i>Foto da medição — @nome
    </h1>
    <p class="small text-muted">A câmara abre dentro desta página (vídeo). Após o envio, na web um gestor <strong>aprova</strong> (todos os caixilhos passam a Medido) ou <strong>rejeita</strong> (pode enviar outra foto).</p>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="ratio ratio-4x3 bg-dark rounded overflow-hidden position-relative mb-3">
                <video id="videoMedicao" playsinline autoplay muted style="object-fit:cover;width:100%;height:100%;"></video>
                <canvas id="canvasMedicao" width="1280" height="720" class="d-none"></canvas>
            </div>
            <div class="d-flex flex-wrap gap-2 mb-3">
                <button type="button" id="btnIniciarCam" class="btn btn-primary btn-sm">
                    <i class="fas fa-video me-1"></i> Iniciar câmara
                </button>
                <button type="button" id="btnCapturar" class="btn btn-success btn-sm" disabled>
                    <i class="fas fa-camera me-1"></i> Capturar foto
                </button>
                <label class="btn btn-outline-secondary btn-sm mb-0">
                    <i class="fas fa-folder-open me-1"></i> Escolher ficheiro
                    <input type="file" id="inputArquivo" accept="image/*" class="d-none" />
                </label>
            </div>
            <div id="previewWrap" class="d-none mb-3">
                <div class="small text-muted mb-1">Pré-visualização</div>
                <img id="imgPreview" class="img-fluid rounded border" alt="Pré-visualização" style="max-height: 320px;" />
            </div>

            <form asp-action="EnviarFotoMedicao" asp-controller="FamiliaCaixilho" method="post" id="formFoto">
                <input type="hidden" name="id" value="@idFamilia" />
                <input type="hidden" name="fotoBase64" id="fotoBase64" />
                <button type="submit" class="btn btn-success" id="btnEnviar" disabled>
                    <i class="fas fa-paper-plane me-1"></i> Enviar foto
                </button>
            </form>
        </div>
    </div>
</div>

<script>
(function () {
    const video = document.getElementById('videoMedicao');
    const canvas = document.getElementById('canvasMedicao');
    const btnIniciar = document.getElementById('btnIniciarCam');
    const btnCapturar = document.getElementById('btnCapturar');
    const inputArquivo = document.getElementById('inputArquivo');
    const fotoBase64 = document.getElementById('fotoBase64');
    const btnEnviar = document.getElementById('btnEnviar');
    const previewWrap = document.getElementById('previewWrap');
    const imgPreview = document.getElementById('imgPreview');
    const form = document.getElementById('formFoto');
    let stream = null;

    function setPreview(dataUrl) {
        fotoBase64.value = dataUrl;
        imgPreview.src = dataUrl;
        previewWrap.classList.remove('d-none');
        btnEnviar.disabled = false;
    }

    btnIniciar.addEventListener('click', async function () {
        try {
            if (stream) {
                stream.getTracks().forEach(function (t) { t.stop(); });
                stream = null;
            }
            stream = await navigator.mediaDevices.getUserMedia({
                video: { facingMode: 'environment', width: { ideal: 1280 }, height: { ideal: 720 } },
                audio: false
            });
            video.srcObject = stream;
            btnCapturar.disabled = false;
        } catch (e) {
            alert('Não foi possível aceder à câmara: ' + (e.message || e));
        }
    });

    btnCapturar.addEventListener('click', function () {
        if (!video.videoWidth) {
            alert('Aguarde o vídeo ou inicie a câmara.');
            return;
        }
        const w = video.videoWidth;
        const h = video.videoHeight;
        canvas.width = w;
        canvas.height = h;
        const ctx = canvas.getContext('2d');
        ctx.drawImage(video, 0, 0, w, h);
        const dataUrl = canvas.toDataURL('image/jpeg', 0.85);
        setPreview(dataUrl);
    });

    inputArquivo.addEventListener('change', function () {
        const f = inputArquivo.files && inputArquivo.files[0];
        if (!f) return;
        const reader = new FileReader();
        reader.onload = function () {
            const img = new Image();
            img.onload = function () {
                const maxW = 1600;
                let tw = img.width, th = img.height;
                if (tw > maxW) {
                    th = (maxW / tw) * th;
                    tw = maxW;
                }
                canvas.width = tw;
                canvas.height = th;
                const ctx = canvas.getContext('2d');
                ctx.drawImage(img, 0, 0, tw, th);
                setPreview(canvas.toDataURL('image/jpeg', 0.85));
            };
            img.src = reader.result;
        };
        reader.readAsDataURL(f);
    });

    form.addEventListener('submit', function (e) {
        if (!fotoBase64.value || fotoBase64.value.length < 50) {
            e.preventDefault();
            alert('Capture ou escolha uma foto antes de enviar.');
        }
    });
})();
</script>
